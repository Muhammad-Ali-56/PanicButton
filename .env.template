# ──────────────────────────────────────────────────
#  PanicButton — Environment Variables
# ──────────────────────────────────────────────────
#  Copy this file to .env and fill in your API key.
#  Only ONE key is required. AICC is checked first.
# ──────────────────────────────────────────────────

# AICC Universal API (recommended — supports any model via api.ai.cc)
AICC_API_KEY=
AICC_MODEL=gpt-4o

# Google Gemini
GEMINI_API_KEY=

# OpenAI GPT (alternative)
OPENAI_API_KEY=
